#
# If zsh is installed, replace this bash shell with a zsh login shell.
# This lets hosts where the login shell is bash (e.g. some servers where you
# can't chsh without root) still drop into the managed zsh setup on login.
if [ -x "$(command -v zsh)" ] && [ -z "${ZSH_VERSION:-}" ]; then
    export SHELL="$(command -v zsh)"
    exec zsh -l
fi
