# Managed by chezmoi. Edit the source at ~/Documents/dotfiles/dot_zshrc
# (do not edit this file directly).

# Host-specific config (SSH agent, extra PATH, secrets, etc.) lives in
# ~/.zshrc.local and is sourced early so PATH/agent are ready before starship.
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

CONFIG_DIR="$HOME/.config/zsh"
DOT_DIR="$HOME/Documents/dotfiles"

ZSH_DISABLE_COMPFIX=true
ZSH=$HOME/.oh-my-zsh
fpath+=${ZSH_CUSTOM:-${ZSH:-~/.oh-my-zsh}/custom}/plugins/zsh-completions/src
autoload -U compinit && compinit
zstyle ':completion:*' matcher-list 'l:|=*'
plugins=(zsh-autosuggestions
	zsh-syntax-highlighting
	zsh-completions
	zsh-history-substring-search
	z
	brew
	git
	you-should-use
	zsh-navigation-tools)

source $ZSH/oh-my-zsh.sh
source $CONFIG_DIR/aliases.sh
source $CONFIG_DIR/extras.sh
source $CONFIG_DIR/slurm.sh
which starship >/dev/null 2>&1 && eval "$(starship init zsh)"
