#!/bin/bash
set -euo pipefail
# Installs OS packages, oh-my-zsh and its plugins.
# This is a chezmoi `run_onchange_` script: it runs on first apply and again
# only when this file's content changes. Bump the version line below to force
# a re-run (the old --force behaviour).
# version: 4

operating_system="$(uname -s)"
case "${operating_system}" in
    Linux*)  machine=Linux;;
    Darwin*) machine=Mac;;
    *)       machine="UNKNOWN:${operating_system}"
esac

# Install starship as a static binary into ~/.local/bin (no root needed).
install_starship_rootless() {
    local bindir="$HOME/.local/bin"
    mkdir -p "$bindir"
    if [ -x "$bindir/starship" ]; then
        echo "starship already present at $bindir/starship"
    else
        echo "Installing starship to $bindir (user-space, no root)..."
        curl -sS https://starship.rs/install.sh | sh -s -- -y -b "$bindir"
    fi
}

# Install git-delta as a static binary into ~/.local/bin (no root needed).
install_delta_rootless() {
    local bindir="$HOME/.local/bin"
    mkdir -p "$bindir"
    if [ -x "$bindir/delta" ]; then
        echo "git-delta already present at $bindir/delta"
        return
    fi
    local arch
    arch="$(uname -m)"
    # Normalise: macOS reports arm64, Linux reports aarch64.
    [ "$arch" = "arm64" ] && arch="aarch64"
    echo "Installing git-delta to $bindir (user-space, no root, arch=$arch)..."
    local delta_url
    # Prefer the musl (fully static) build; fall back to the gnu (glibc) build.
    delta_url=$(curl -fsSL https://api.github.com/repos/dandavison/delta/releases/latest \
        | grep '"browser_download_url"' \
        | grep "${arch}-unknown-linux-musl.tar.gz" \
        | head -1 \
        | cut -d'"' -f4) || true
    if [ -z "$delta_url" ]; then
        delta_url=$(curl -fsSL https://api.github.com/repos/dandavison/delta/releases/latest \
            | grep '"browser_download_url"' \
            | grep "${arch}-unknown-linux-gnu.tar.gz" \
            | head -1 \
            | cut -d'"' -f4) || true
    fi
    if [ -z "$delta_url" ]; then
        echo "WARNING: could not find a git-delta binary for ${arch}; skipping."
        return
    fi
    local tmpdir
    tmpdir="$(mktemp -d)"
    curl -fsSL "$delta_url" | tar xz -C "$tmpdir"
    cp "$tmpdir"/delta-*/delta "$bindir/delta"
    rm -rf "$tmpdir"
}

# Warn that a tool can't be installed without root.
warn_no_root() {
    local tool="$1"
    if command -v "$tool" >/dev/null 2>&1; then
        echo "$tool already installed at $(command -v "$tool")"
    else
        echo "WARNING: cannot install $tool without root; install it manually."
    fi
}

# Install agent-of-empires (aoe) via the official install.sh script.
# The script installs a static binary into ~/.local/bin (no root needed) on
# both Linux and macOS. aoe hard-requires tmux, so enabling `installAoe`
# also forces tmux to be installed via the package manager (see the
# `or .installAoe` guards on the tmux install lines below).
install_aoe() {
    local bindir="$HOME/.local/bin"
    if command -v aoe >/dev/null 2>&1; then
        echo "aoe already installed at $(command -v aoe)"
        return
    fi
    echo "Installing agent-of-empires (aoe) to $bindir..."
    curl -fsSL \
        https://raw.githubusercontent.com/agent-of-empires/agent-of-empires/main/scripts/install.sh \
        | INSTALL_DIR="$bindir" bash
}

if [ "$machine" = "Linux" ]; then
    if sudo -n true 2>/dev/null; then
        sudo apt-get install -y git-delta starship
{{- if .installZsh }}
        sudo apt-get install -y zsh
{{- end }}
{{- if or .installTmux .installAoe }}
        sudo apt-get install -y tmux
{{- end }}
    else
        echo "No passwordless sudo on this host; installing to ~/.local/bin (user-space)."
        install_starship_rootless
        install_delta_rootless
{{- if .installZsh }}
        warn_no_root zsh
{{- end }}
{{- if or .installTmux .installAoe }}
        warn_no_root tmux
{{- end }}
    fi
{{- if .installAoe }}
    install_aoe
{{- end }}
elif [ "$machine" = "Mac" ]; then
    brew install coreutils git-delta starship
{{- if .installZsh }}
    brew install zsh
{{- end }}
{{- if or .installTmux .installAoe }}
    brew install tmux
{{- end }}
{{- if .installAoe }}
    brew install aoe
{{- end }}
fi

# oh-my-zsh and plugins
ZSH="$HOME/.oh-my-zsh"
ZSH_CUSTOM="$ZSH/custom"
if [ -d "$ZSH" ]; then
    echo "oh-my-zsh already present at $ZSH, skipping plugin install"
else
    echo "Installing oh-my-zsh and plugins..."
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended

    git clone https://github.com/romkatv/powerlevel10k.git \
        "$ZSH_CUSTOM/themes/powerlevel10k"

    git clone https://github.com/zsh-users/zsh-syntax-highlighting.git \
        "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"

    git clone https://github.com/zsh-users/zsh-autosuggestions \
        "$ZSH_CUSTOM/plugins/zsh-autosuggestions"

    git clone https://github.com/zsh-users/zsh-completions \
        "$ZSH_CUSTOM/plugins/zsh-completions"

    git clone https://github.com/zsh-users/zsh-history-substring-search \
        "$ZSH_CUSTOM/plugins/zsh-history-substring-search"

    git clone https://github.com/MichaelAquilina/zsh-you-should-use \
        "$ZSH_CUSTOM/plugins/you-should-use"
fi

# Local/private git config include (gitconfig sources this via [include])
touch "$HOME/.gitconfig.local"
